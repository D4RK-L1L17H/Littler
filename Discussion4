#include <iostream>
using namespace std;

const int MAX = 20;

// Reads count integers into arr
void readArray(int arr[], int count) {
    for (int i = 0; i < count; i++) {
        cin >> arr[i];
    }
}

void shiftArray(int arr[], int count, int startIndex) {
    for (int i = 0; i < startIndex; i++) {
        int temp = arr[0];             
        for (int j = 0; j < count - 1; j++) {
            arr[j] = arr[j + 1];
        }
        arr[count - 1] = temp;
    }
}

void printArray(int arr[], int count) {
    for (int i = 0; i < count; i++) {
        cout << arr[i] << " ";
    }
    cout << endl;
}

int main() {
    int arr[MAX];
    int count, startIndex;

    cout << "Number of integers: ";
    cin >> count;
    while (count < 1 || count > MAX) {
        cout << "Invalid! Enter a number between 1 and " << MAX << ": ";
        cin >> count;
    }

    cout << "Enter the values: ";
    readArray(arr, count);

    cout << "Enter start index: ";
    cin >> startIndex;
    while (startIndex < 0 || startIndex >= count) {
        cout << "Invalid! Enter an index between 0 and " << count - 1 << ": ";
        cin >> startIndex;
    }

    shiftArray(arr, count, startIndex);
    printArray(arr, count);

    return 0;
}
